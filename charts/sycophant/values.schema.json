{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "controller": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "tag"],
      "properties": {
        "image": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "airlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "tag"],
      "properties": {
        "image": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "transponder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "tag"],
      "properties": {
        "image": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "workspaces": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["image", "tag", "agents"],
        "additionalProperties": false,
        "properties": {
          "image": { "type": "string" },
          "tag": { "type": "string" },
          "pullPolicy": {
            "type": "string",
            "enum": ["Always", "IfNotPresent", "Never"]
          },
          "agents": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string" },
                "description": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "chambers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["workspace", "workspaceMode"],
        "additionalProperties": false,
        "properties": {
          "workspace": { "type": "string" },
          "workspaceMode": {
            "type": "string",
            "enum": ["readOnly", "readWrite"]
          },
          "workspaceMountPath": { "type": "string" },
          "keepalive": { "type": "boolean" },
          "credentials": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["secret"],
              "additionalProperties": false,
              "properties": {
                "secret": { "type": "string" },
                "key": { "type": "string" },
                "env": { "type": "string" },
                "file": { "type": "string" }
              }
            }
          },
          "egress": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["host", "port"],
              "additionalProperties": false,
              "properties": {
                "host": { "type": "string" },
                "port": { "type": "integer" }
              }
            }
          }
        }
      }
    },
    "tools": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["chamber", "description", "image", "command"],
        "additionalProperties": false,
        "properties": {
          "chamber": { "type": "string" },
          "description": { "type": "string" },
          "image": { "type": "string" },
          "command": { "type": "string" },
          "maxCalls": {
            "type": "integer",
            "minimum": 0,
            "default": 0
          }
        }
      }
    }
  }
}
