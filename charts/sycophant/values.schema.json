{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "controller": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "tag"],
      "properties": {
        "image": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "airlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "tag"],
      "properties": {
        "image": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "transponder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "tag"],
      "properties": {
        "image": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "workspaces": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["image", "tag", "agents"],
        "additionalProperties": false,
        "properties": {
          "image": { "type": "string" },
          "tag": { "type": "string" },
          "pullPolicy": {
            "type": "string",
            "enum": ["Always", "IfNotPresent", "Never"]
          },
          "agents": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string" },
                "description": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
