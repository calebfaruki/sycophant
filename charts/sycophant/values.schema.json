{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "controller": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "tag"],
      "properties": {
        "image": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "llmJobImage": { "type": "string" }
      }
    },
    "airlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "tag"],
      "properties": {
        "image": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "transponder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "tag"],
      "properties": {
        "image": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "mainframe": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "adapter": {
          "type": "string",
          "enum": ["local"]
        },
        "local": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "hostPath": { "type": "string" },
            "storageClass": { "type": "string" },
            "capacity": { "type": "string" }
          }
        }
      }
    },
    "workspaces": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["image", "tag"],
        "additionalProperties": false,
        "properties": {
          "image": { "type": "string" },
          "tag": { "type": "string" },
          "pullPolicy": {
            "type": "string",
            "enum": ["Always", "IfNotPresent", "Never"]
          },
          "chambers": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "chambers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["workspaceMode"],
        "additionalProperties": false,
        "properties": {
          "workspaceMode": {
            "type": "string",
            "enum": ["readOnly", "readWrite"]
          },
          "image": { "type": "string" },
          "workspaceMountPath": { "type": "string" },
          "keepalive": { "type": "boolean" },
          "credentials": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["secret"],
              "additionalProperties": false,
              "properties": {
                "secret": { "type": "string" },
                "env": { "type": "string" },
                "file": { "type": "string" }
              }
            }
          },
          "egress": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["host", "port"],
              "additionalProperties": false,
              "properties": {
                "host": { "type": "string" },
                "port": { "type": "integer" }
              }
            }
          }
        }
      }
    },
    "models": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["format", "model", "baseUrl"],
        "additionalProperties": false,
        "properties": {
          "format": { "type": "string" },
          "model": { "type": "string" },
          "baseUrl": { "type": "string" },
          "thinking": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "secret": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "env": { "type": "string" },
              "file": { "type": "string" }
            }
          }
        }
      }
    },
    "channels": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type", "secretName", "image"],
        "additionalProperties": false,
        "properties": {
          "type": { "type": "string" },
          "secretName": { "type": "string" },
          "image": { "type": "string" }
        }
      }
    }
  }
}
